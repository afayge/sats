WEB_SEARCH_MAX_RESULTS=10
WEB_SEARCH_BACKEND=auto
WEB_SEARCH_PROVIDERS=ddgs,bing
WEB_PAGE_CACHE_TTL_SECONDS=86400
WEB_RESPONSES_BASE_URL=
WEB_RESPONSES_API_KEY=
WEB_RESPONSES_MODEL=
